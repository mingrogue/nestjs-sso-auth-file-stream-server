{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/sso-auth/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/sso-auth/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/sso-auth",
  "projects": {
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "sso-auth": {
      "type": "application",
      "root": "apps/sso-auth",
      "entryFile": "main",
      "sourceRoot": "apps/sso-auth/src",
      "compilerOptions": {
        "tsConfigPath": "apps/sso-auth/tsconfig.app.json",
        "webpack": false
      }
    },
    "streaming": {
      "type": "application",
      "root": "apps/streaming",
      "entryFile": "main",
      "sourceRoot": "apps/streaming/src",
      "compilerOptions": {
        "tsConfigPath": "apps/streaming/tsconfig.app.json",
        "webpack": false
      }
    }
  }
}